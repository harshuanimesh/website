{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2017", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@website/configurable-fields": ["libs/configurable-fields/src/index.ts"],
      "@website/constants": ["libs/constants/src/index.ts"],
      "@website/generic-service": ["libs/generic-service/src/index.ts"],
      "@website/interfaces": ["libs/interfaces/src/index.ts"],
      "@website/shared": ["libs/shared/src/index.ts"],
      "@website/shared-admin": ["libs/shared-admin/src/index.ts"],
      "@website/shared-stallion": ["libs/shared-stallion/src/index.ts"],
      "@website/shared/artifacts": ["libs/shared/artifacts/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
